<mxfile host="app.diagrams.net">
  <diagram id="stack-composition" name="Stack構成">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="950" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="CDK Stack構成（依存関係 / 非依存関係）" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1420" height="40" as="geometry" />
        </mxCell>

        <mxCell id="region-apne1" value="region: ap-northeast-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;dashed=1;verticalAlign=top;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1080" height="800" as="geometry" />
        </mxCell>

        <mxCell id="region-use1" value="region: us-east-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#cc8800;dashed=1;verticalAlign=top;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1140" y="80" width="320" height="800" as="geometry" />
        </mxCell>

        <mxCell id="layer-shared" value="shared層（環境ごと1つ・長命）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;verticalAlign=top;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="540" height="200" as="geometry" />
        </mxCell>

        <mxCell id="layer-shared-use1" value="shared層（us-east-1）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;verticalAlign=top;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1160" y="120" width="300" height="200" as="geometry" />
        </mxCell>

        <mxCell id="layer-app-use1" value="app層（us-east-1）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;verticalAlign=top;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1160" y="360" width="300" height="370" as="geometry" />
        </mxCell>

        <mxCell id="shared-stack" value="SharedStack&#10;pf-${sharedEnv}-shared&#10;&#10;・SharedMeta（contract version）&#10;・SharedSes（fromEmail / Arn）&#10;・SharedHostedZone（baseDomain）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#0d47a1;align=left;verticalAlign=top;fontStyle=1;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="240" height="140" as="geometry" />
        </mxCell>

        <mxCell id="ssm" value="SSM Parameter Store&#10;/pf/shared/&lt;env&gt;/...&#10;（meta / domain / ses）" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff3e0;strokeColor=#e65100;align=center;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="380" y="170" width="200" height="120" as="geometry" />
        </mxCell>

        <mxCell id="shared-use1" value="SharedUsEast1ParamsStack&#10;pf-${sharedEnv}-shared-us-east-1-params&#10;&#10;・SSM同期配置（meta / domain / ses）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#0d47a1;align=left;verticalAlign=top;fontStyle=1;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="1180" y="160" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ssm-use1" value="SSM Parameter Store&#10;(us-east-1)&#10;/pf/shared/&lt;env&gt;/..." style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff3e0;strokeColor=#e65100;align=center;fontStyle=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="1230" y="248" width="160" height="62" as="geometry" />
        </mxCell>

        <mxCell id="layer-app" value="app層（stage単位・破棄前提）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;verticalAlign=top;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="1040" height="370" as="geometry" />
        </mxCell>

        <mxCell id="db-stack" value="DbStack&#10;${prefix}-db&#10;&#10;・Aurora DSQL Cluster" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#1b5e20;align=left;verticalAlign=top;fontStyle=1;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="200" height="110" as="geometry" />
        </mxCell>

        <mxCell id="storage-stack" value="StorageStack&#10;${prefix}-storage&#10;&#10;・S3（image保存）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#1b5e20;align=left;verticalAlign=top;fontStyle=1;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="320" y="400" width="200" height="110" as="geometry" />
        </mxCell>

        <mxCell id="auth-stack" value="AuthStack&#10;${prefix}-auth&#10;&#10;・Cognito UserPool / Client&#10;・IdentityPool&#10;・Trigger Lambda" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#1b5e20;align=left;verticalAlign=top;fontStyle=1;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="560" y="400" width="200" height="110" as="geometry" />
        </mxCell>

        <mxCell id="api-stack" value="ApiStack&#10;${prefix}-api&#10;&#10;・API Gateway HTTP API&#10;・Lambda（GraphQL）&#10;・Custom Domain（api.${stage}.${baseDomain}）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#1b5e20;align=left;verticalAlign=top;fontStyle=1;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="320" y="570" width="280" height="130" as="geometry" />
        </mxCell>

        <mxCell id="ops-stack" value="OpsStack&#10;${prefix}-ops&#10;&#10;・S3（migration zip）&#10;・MigrationRunner Lambda" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#1b5e20;align=left;verticalAlign=top;fontStyle=1;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="80" y="570" width="200" height="130" as="geometry" />
        </mxCell>

        <mxCell id="web-stack" value="WebStack&#10;${prefix}-web&#10;&#10;・S3（静的配信）&#10;・CloudFront Distribution&#10;・BucketDeployment&#10;・Custom Domain（web.${stage}.${baseDomain}）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#1b5e20;align=left;verticalAlign=top;fontStyle=1;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="640" y="570" width="320" height="140" as="geometry" />
        </mxCell>

        <mxCell id="webcert-stack" value="WebCertificateStack&#10;${prefix}-web-cert&#10;&#10;・ACM Certificate（CloudFront用）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#1b5e20;align=left;verticalAlign=top;fontStyle=1;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="1180" y="400" width="260" height="120" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="凡例（矢印タイプ）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#666;align=left;verticalAlign=top;fontStyle=1;fontSize=12;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="80" y="750" width="1360" height="120" as="geometry" />
        </mxCell>

        <mxCell id="lg-dep-line" style="endArrow=block;html=1;rounded=0;strokeColor=#c62828;strokeWidth=4;startArrow=diamondThin;startFill=1;startSize=12;endFill=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="110" y="790" as="sourcePoint" />
            <mxPoint x="240" y="790" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lg-dep-text" value="◆━━▶ 依存関係（addDependency）：被参照側の削除/更新が deploy/destroy 順序を制約。被参照を消すと参照側に影響" style="text;html=1;align=left;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="260" y="780" width="1100" height="20" as="geometry" />
        </mxCell>

        <mxCell id="lg-ref-line" style="endArrow=open;html=1;rounded=0;strokeColor=#1976d2;strokeWidth=2;dashed=1;dashPattern=8 4" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="110" y="822" as="sourcePoint" />
            <mxPoint x="240" y="822" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lg-ref-text" value="┄┄→ 非依存・CFN参照のみ：値（Output / cross-region / SSM）を渡すだけ。addDependency なし → 削除順序の制約なし" style="text;html=1;align=left;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="260" y="812" width="1100" height="20" as="geometry" />
        </mxCell>

        <mxCell id="lg-ssm-line" style="endArrow=open;html=1;rounded=0;strokeColor=#888;strokeWidth=1;dashed=1;dashPattern=2 2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="110" y="852" as="sourcePoint" />
            <mxPoint x="240" y="852" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lg-ssm-text" value="┈┈→ SSM lookup（synth時に値解決）：CFN依存ではない。shared層を消すと次の synth で参照不能になる注意あり" style="text;html=1;align=left;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="260" y="842" width="1100" height="20" as="geometry" />
        </mxCell>

        <mxCell id="e-shared-ssm" style="endArrow=block;html=1;rounded=0;strokeColor=#c62828;strokeWidth=4;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;startArrow=diamondThin;startFill=1;startSize=12;endFill=1" edge="1" parent="1" source="shared-stack" target="ssm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-shared-use1" style="endArrow=block;html=1;rounded=0;strokeColor=#c62828;strokeWidth=4;exitX=1;exitY=0.4;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;startArrow=diamondThin;startFill=1;startSize=12;endFill=1" edge="1" parent="1" source="ssm" target="shared-use1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-shared-use1-l" value="addDependency&#10;cross-region同期&#10;props経由で値受領" style="text;html=1;align=center;fontSize=10;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="780" y="160" width="160" height="50" as="geometry" />
        </mxCell>

        <mxCell id="e-use1-ssm" style="endArrow=block;html=1;rounded=0;strokeColor=#c62828;strokeWidth=4;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;startArrow=diamondThin;startFill=1;startSize=12;endFill=1" edge="1" parent="1" source="shared-use1" target="ssm-use1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-api-db" style="endArrow=block;html=1;rounded=0;strokeColor=#c62828;strokeWidth=4;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.3;entryY=0;entryDx=0;entryDy=0;startArrow=diamondThin;startFill=1;startSize=12;endFill=1" edge="1" parent="1" source="db-stack" target="api-stack">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-api-db-l" value="addDependency&#10;dbClusterArn / endpoint" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#c62828" vertex="1" parent="1">
          <mxGeometry x="180" y="525" width="160" height="30" as="geometry" />
        </mxCell>

        <mxCell id="e-api-storage" style="endArrow=block;html=1;rounded=0;strokeColor=#c62828;strokeWidth=4;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;startArrow=diamondThin;startFill=1;startSize=12;endFill=1" edge="1" parent="1" source="storage-stack" target="api-stack">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-api-storage-l" value="addDependency&#10;imageBucketName / prefix" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#c62828" vertex="1" parent="1">
          <mxGeometry x="360" y="525" width="170" height="30" as="geometry" />
        </mxCell>

        <mxCell id="e-api-auth" style="endArrow=block;html=1;rounded=0;strokeColor=#c62828;strokeWidth=4;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.85;entryY=0;entryDx=0;entryDy=0;startArrow=diamondThin;startFill=1;startSize=12;endFill=1" edge="1" parent="1" source="auth-stack" target="api-stack">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-api-auth-l" value="addDependency&#10;userPoolId / ClientId" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#c62828" vertex="1" parent="1">
          <mxGeometry x="540" y="525" width="160" height="30" as="geometry" />
        </mxCell>

        <mxCell id="e-ops-db" style="endArrow=block;html=1;rounded=0;strokeColor=#c62828;strokeWidth=4;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;startArrow=diamondThin;startFill=1;startSize=12;endFill=1" edge="1" parent="1" source="db-stack" target="ops-stack">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-ops-db-l" value="addDependency" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#c62828" vertex="1" parent="1">
          <mxGeometry x="80" y="525" width="100" height="20" as="geometry" />
        </mxCell>

        <mxCell id="e-web-api" style="endArrow=open;html=1;rounded=0;dashed=1;dashPattern=8 4;strokeColor=#1976d2;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="api-stack" target="web-stack">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-web-api-l" value="参照のみ&#10;apiUrl" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#1976d2" vertex="1" parent="1">
          <mxGeometry x="600" y="610" width="80" height="30" as="geometry" />
        </mxCell>

        <mxCell id="e-web-auth" style="endArrow=open;html=1;rounded=0;dashed=1;dashPattern=8 4;strokeColor=#1976d2;strokeWidth=2;exitX=0.7;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="auth-stack" target="web-stack">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-web-auth-l" value="参照のみ&#10;userPool*" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#1976d2" vertex="1" parent="1">
          <mxGeometry x="730" y="525" width="100" height="30" as="geometry" />
        </mxCell>

        <mxCell id="e-web-cert" style="endArrow=open;html=1;rounded=0;dashed=1;dashPattern=8 4;strokeColor=#1976d2;strokeWidth=2;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0" edge="1" parent="1" source="webcert-stack" target="web-stack">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-web-cert-l" value="参照のみ&#10;certificate&#10;(crossRegion)" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#1976d2" vertex="1" parent="1">
          <mxGeometry x="1000" y="540" width="120" height="40" as="geometry" />
        </mxCell>

        <mxCell id="e-db-ssm" style="endArrow=open;html=1;rounded=0;dashed=1;dashPattern=2 2;strokeColor=#888;strokeWidth=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.3;entryY=1;entryDx=0;entryDy=0" edge="1" parent="1" source="db-stack" target="ssm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-storage-ssm" style="endArrow=open;html=1;rounded=0;dashed=1;dashPattern=2 2;strokeColor=#888;strokeWidth=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0" edge="1" parent="1" source="storage-stack" target="ssm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-auth-ssm" style="endArrow=open;html=1;rounded=0;dashed=1;dashPattern=2 2;strokeColor=#888;strokeWidth=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.7;entryY=1;entryDx=0;entryDy=0" edge="1" parent="1" source="auth-stack" target="ssm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="ssm-note" value="※ app層は SSM lookup（synth時）&#10;　shared層への CFN 依存は無し" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#666" vertex="1" parent="1">
          <mxGeometry x="600" y="330" width="240" height="30" as="geometry" />
        </mxCell>

        <mxCell id="e-cert-ssm" style="endArrow=open;html=1;rounded=0;dashed=1;dashPattern=2 2;strokeColor=#888;strokeWidth=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0" edge="1" parent="1" source="webcert-stack" target="ssm-use1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-cert-ssm-l" value="SSM lookup&#10;(同リージョン)" style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#666" vertex="1" parent="1">
          <mxGeometry x="1180" y="335" width="120" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
