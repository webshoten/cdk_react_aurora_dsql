{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "includes": [
      "packages/**/*.ts",
      "packages/**/*.tsx",
      "packages/**/*.json",
      "scripts/**/*.ts",
      "biome.json",
      "package.json",
      "tsconfig.json",
      "tsconfig.base.json",
      "!!**/node_modules",
      "!!**/cdk.out",
      "!!**/dist"
    ],
    "ignoreUnknown": true
  }
}
