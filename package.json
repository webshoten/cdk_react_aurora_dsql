{
  "name": "cdk-pf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "cdk": "pnpm --filter @pf/infra cdk",
    "cdk:deploy": "tsx scripts/cdk.ts deploy",
    "cdk:deploy:shared": "tsx scripts/cdk.ts deploy-shared",
    "cdk:diff": "tsx scripts/cdk.ts diff",
    "cdk:destroy": "tsx scripts/cdk.ts destroy",
    "cdk:destroy:shared": "tsx scripts/cdk.ts destroy-shared",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "migrate": "tsx scripts/migrate.ts",
    "local-dev:resolve-env": "tsx scripts/local-dev/resolve-env.ts",
    "dev:web": "pnpm --filter @pf/web dev",
    "dev:functions": "pnpm --filter @pf/functions dev",
    "graphql:extract": "pnpm --filter @pf/functions graphql:extract",
    "graphql:genql": "pnpm --filter @pf/graphql-schema graphql:genql",
    "graphql:build": "pnpm graphql:extract && pnpm graphql:genql",
    "qa": "pnpm qa:static && pnpm qa:base",
    "qa:base": "pnpm lint && pnpm qa:backend",
    "qa:static": "docker run --rm -v \"$PWD:/src\" semgrep/semgrep semgrep --config p/owasp-top-ten --config p/secrets --config p/typescript /src",
    "qa:frontend": "pnpm --filter @pf/web exec tsc --noEmit && pnpm --filter @pf/web build && pnpm dlx react-doctor . --project @pf/web",
    "qa:backend": "pnpm --filter @pf/core exec tsc --noEmit && pnpm --filter @pf/functions exec tsc --noEmit && pnpm graphql:build",
    "qa:infra": "test -n \"$CDK_SHARED_ENV\" && CDK_NAG=1 pnpm --filter @pf/infra cdk synth --all --no-lookups --context shared-env=$CDK_SHARED_ENV",
    "qa:security": "pnpm qa:static",
    "qa:full": "pnpm qa:static && pnpm qa:backend && pnpm qa:frontend && pnpm qa:infra",
    "user:create": "tsx scripts/create-user.ts",
    "user:delete": "tsx scripts/delete-user.ts",
    "env:set": "tsx scripts/env.ts set",
    "env:list": "tsx scripts/env.ts list"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "aws-cdk": "^2.1119.0",
    "commander": "^14.0.3",
    "fflate": "^0.8.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.15.0"
  }
}
