{
  "name": "cdk-pf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "cdk": "pnpm --filter @pf/infra cdk",
    "cdk:deploy": "tsx scripts/cdk.ts deploy",
    "cdk:deploy:shared": "tsx scripts/cdk.ts deploy-shared",
    "cdk:diff": "tsx scripts/cdk.ts diff",
    "cdk:destroy": "tsx scripts/cdk.ts destroy",
    "cdk:destroy:shared": "tsx scripts/cdk.ts destroy-shared",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "dev:web": "pnpm --filter @pf/web dev",
    "dev:functions": "pnpm --filter @pf/functions dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "aws-cdk": "^2.1119.0",
    "commander": "^14.0.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.15.0"
  }
}
